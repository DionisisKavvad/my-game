# Database
POSTGRES_DB=hero_wars
POSTGRES_USER=hero
POSTGRES_PASSWORD=hero_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hero:hero_dev@localhost:5432/hero_wars?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-super-secret-key
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_TTL=2592000

# App
PORT=3000
NODE_ENV=development
